{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/health",       "destination": "/api/index.js" },
    { "source": "/api/:path*",   "destination": "/api/index.js" },
    { "source": "/((?!api).*)",  "destination": "/index.html"   }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
